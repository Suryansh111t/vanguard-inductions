<?xml version="1.0"?>
<!--
  arm3dof.urdf  -  A 3-DOF (3 joint) robotic arm, written in PLAIN URDF (no Xacro).

  Kinematic chain (parent -> child), all revolute joints:

    base_link
      |  base_yaw      (revolute, axis Z)  <- rotates the whole arm left/right
    link1  (hub)
      |  shoulder_pitch(revolute, axis Y)  <- tips the arm forward/back
    link2  (upper arm, length L2 = 0.25 m)
      |  elbow_pitch   (revolute, axis Y)  <- bends the "elbow"
    link3  (forearm,   length L3 = 0.25 m)
      |  tip_joint     (fixed)
    tip_link (gripper point / end-effector)

  Geometry constants that the IK code MUST match (see arm3dof/ik.py):
    D1 = 0.10 m   base_link origin  -> shoulder joint (vertical)
    L2 = 0.25 m   shoulder          -> elbow
    L3 = 0.25 m   elbow             -> tip
  At all-zero joint angles the arm points straight UP (+Z).
-->
<robot name="arm3dof">

  <!-- ===== Materials (just colours for RViz/Gazebo) ===== -->
  <material name="grey">   <color rgba="0.4 0.4 0.4 1.0"/></material>
  <material name="blue">   <color rgba="0.1 0.3 0.8 1.0"/></material>
  <material name="orange"> <color rgba="0.9 0.5 0.1 1.0"/></material>
  <material name="green">  <color rgba="0.1 0.7 0.2 1.0"/></material>
  <material name="red">    <color rgba="0.8 0.1 0.1 1.0"/></material>

  <!-- ============================================================
       base_link : the pedestal bolted to the rover. Its origin is
       our reference frame (0,0,0). In RViz set Fixed Frame = base_link.
       ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder radius="0.09" length="0.06"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder radius="0.09" length="0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 1 - base_yaw : rotate the whole arm about vertical Z
       ============================================================ -->
  <joint name="base_yaw" type="revolute">
    <parent link="base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="30" velocity="2.0"/>
  </joint>

  <!-- link1 : small rotating hub that carries the shoulder -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0006"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 2 - shoulder_pitch : tip the arm forward/back about Y.
       Origin is D1 = 0.10 m above the base_link origin (0.06 up from
       base_link to here on link1, plus this 0.04 = 0.10 total).
       ============================================================ -->
  <joint name="shoulder_pitch" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.7" upper="2.7" effort="30" velocity="2.0"/>
  </joint>

  <!-- link2 : the UPPER ARM, L2 = 0.25 m long, drawn along +Z -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.25"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.25"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.0043" ixy="0" ixz="0" iyy="0.0043" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 3 - elbow_pitch : bend the elbow about Y.
       Origin is L2 = 0.25 m up from the shoulder (top of link2).
       ============================================================ -->
  <joint name="elbow_pitch" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.7" upper="2.7" effort="30" velocity="2.0"/>
  </joint>

  <!-- link3 : the FOREARM, L3 = 0.25 m long, drawn along +Z -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.25"/></geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.25"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0027" ixy="0" ixz="0" iyy="0.0027" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- ============================================================
       tip_joint (fixed) : marks the gripper / end-effector point,
       L3 = 0.25 m up from the elbow (top of link3).
       ============================================================ -->
  <joint name="tip_joint" type="fixed">
    <parent link="link3"/>
    <child  link="tip_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>

  <link name="tip_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00004" ixy="0" ixz="0" iyy="0.00004" iyz="0" izz="0.00004"/>
    </inertial>
  </link>

  <!-- ============================================================
       GAZEBO EXTRAS (ignored by RViz).  Only needed for the optional
       Gazebo Classic demo (see launch/gazebo.launch.py). ros2_control
       lets a controller command the three joints in physics.
       ============================================================ -->
  <gazebo reference="base_link"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="link1"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link2"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link3"><material>Gazebo/Green</material></gazebo>
  <gazebo reference="tip_link"><material>Gazebo/Red</material></gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="base_yaw">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder_pitch">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow_pitch">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find arm3dof)/config/arm_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
